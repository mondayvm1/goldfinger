# ── Kalshi API credentials (standalone mode) ─────────────────
# Get from: https://kalshi.com/account/api
KALSHI_API_KEY=your-kalshi-api-key-id
KALSHI_PRIVATE_KEY_PATH=config/kalshi_private_key.pem

# ── Multi-user mode ──────────────────────────────────────────
# Fernet key for decrypting user credentials (shared with web/)
# Generate: python -m src.crypto
FERNET_KEY=your-fernet-key-base64

# Service-to-service auth (Next.js → Engine)
ENGINE_API_KEY=your-engine-api-key

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://goldfinger.vercel.app
