# ── Kalshi API credentials ──────────────────────────────
# Get from: https://kalshi.com/account/api
KALSHI_API_KEY=your-kalshi-api-key-id
KALSHI_PRIVATE_KEY_PATH=path/to/kalshi_private_key.pem

# ── Polymarket credentials ──────────────────────────────
# CLOB API creds (from: https://clob.polymarket.com/)
POLYMARKET_API_KEY=your-clob-api-key
POLYMARKET_SECRET=your-clob-secret
POLYMARKET_PASSPHRASE=your-clob-passphrase

# Your wallet address (0x... , 42 chars)
POLYMARKET_ADDRESS=your-wallet-address-here

# Your wallet private key (0x + 64 hex chars) — ONLY needed for placing orders
POLYMARKET_PRIVATE_KEY=your-polygon-private-key-hex
