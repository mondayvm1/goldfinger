# ── Database (Neon serverless Postgres) ──────────────────────
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/goldfinger?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ── Google OAuth ─────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Fernet Encryption Key (shared with engine) ──────────────
# Generate: cd engine && python -m src.crypto
FERNET_KEY="your-fernet-key-base64"

# ── Engine Connection ────────────────────────────────────────
ENGINE_URL="http://localhost:8050"
ENGINE_API_KEY="your-engine-api-key"
